generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // used by app (pooler)
  directUrl = env("DIRECT_URL")     // used for db push / migrations
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?  @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips     Trip[]
  purchases Purchase[]

  @@map("users")
}

model Trip {
  id          String   @id @default(cuid())
  userId      String
  title       String
  origin      String?
  destination String
  duration    String?
  budget      String?
  groupSize   String?
  interests   String?
  tripData    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("trips")
}

model Purchase {
  id              String   @id @default(cuid())
  userId          String
  planId          String
  planName        String
  amount          Int
  currency        String
  paymentId       String   @unique
  orderId         String
  razorpayOrderId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([userId, createdAt])
  @@map("purchases")
}
